# ─────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection for the LangGraph checkpointer. Get this
# from Supabase Dashboard → Project Settings → Database → Connection string
# (use the "Session" connection, not pooler, for LangGraph).
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ─────────────────────────────────────────────────────────────
# LLM Tiers (OpenAI-compatible).
#  - SUPERVISOR: high intelligence (router)
#  - WRITER:     medium/high (lesson generation, search synthesis)
#  - CRITIC:     medium (pedagogical evaluation of writer drafts) — OPTIONAL
#  - UTILITY:    fast/cheap (picker, language detector, classifications)
# Supervisor / writer / utility are REQUIRED. Boot fails fast if any are missing.
# CRITIC_LLM_* is OPTIONAL — if unset, the critic falls back to the utility tier
# (audit §2.4). Setting it explicitly lets ops route the critic to a medium-tier
# model without dragging the picker / language detector with it (audit §6.1).
# ─────────────────────────────────────────────────────────────
SUPERVISOR_LLM_API_KEY=
SUPERVISOR_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
SUPERVISOR_LLM_MODEL=mistralai/mistral-small-4-119b-2603

WRITER_LLM_API_KEY=
WRITER_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
WRITER_LLM_MODEL=mistralai/mistral-small-4-119b-2603

UTILITY_LLM_API_KEY=
UTILITY_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
UTILITY_LLM_MODEL=mistralai/mistral-small-4-119b-2603

# Optional — falls back to UTILITY_LLM_* when unset.
CRITIC_LLM_API_KEY=
CRITIC_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
CRITIC_LLM_MODEL=mistralai/mistral-small-4-119b-2603

# ─────────────────────────────────────────────────────────────
# Search
# Set either TAVILY_API_KEY (preferred, takes precedence) or
# SERPR_API_KEY. If both are unset, the pedagogy_planner falls
# back to LLM-only research and `/threads` Syllabus search-subgraph
# returns no organic results.
# ─────────────────────────────────────────────────────────────
TAVILY_API_KEY=
SERPR_API_KEY=

# ─────────────────────────────────────────────────────────────
# Cache
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────────
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Web (Next.js public env)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
